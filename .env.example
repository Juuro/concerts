# Database (Vercel Postgres)
# These are auto-populated when you create a Postgres database in Vercel
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=verify-full"
# Vercel Postgres: use the pooled Prisma URL in production (reduces connection spikes).
# POSTGRES_PRISMA_URL="postgresql://..."
# Optional override for pg Pool size (default: 1 on Vercel, 10 locally).
# PG_POOL_MAX=1

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OAuth Providers
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
# Optional: admin feedback escalation target and token
# Format: owner/repo (e.g. Juuro/concerts)
GITHUB_FEEDBACK_REPO=""
# Classic PAT: repo + project (issues + Project V2), or fine-grained with Issues + Projects
GITHUB_FEEDBACK_TOKEN=""
# Optional local fallback if you already use a single PAT elsewhere (prefer GITHUB_FEEDBACK_TOKEN above)
# GH_ACCESS_TOKEN=""
# Optional: separate token for GraphQL Project V2 only (otherwise GITHUB_FEEDBACK_TOKEN is used)
# GITHUB_PROJECT_TOKEN=""
# Link new issues to a GitHub Project (V2). Leave owner/number empty to skip.
# GITHUB_PROJECT_NODE_ID=""
# Concertivity board: owner Juuro, project number 2 — https://github.com/users/Juuro/projects/2/views/1
GITHUB_PROJECT_OWNER=""
GITHUB_PROJECT_NUMBER=""
# Optional: set a default Project Status for newly linked issues.
# Must match a Status column name (case-insensitive). If omitted or unmatched, status is left empty.
# GITHUB_PROJECT_STATUS_OPTION_NAME="Todo"
# When true, syncing a closed GitHub issue sets feedback triage to DONE (audit logged).
# FEEDBACK_GITHUB_CLOSE_SETS_DONE="false"
# Vercel Cron: `GET /api/cron/feedback-github-sync` with `Authorization: Bearer <secret>`
# CRON_SECRET=""
# Optional: permanently delete AppFeedback rows older than this many days (cron: /api/cron/feedback-retention).
# If unset or invalid, the retention cron returns skipped=true and deletes nothing.
# WARNING: Permanently removes DONE/DISCARDED feedback older than this window (including GitHub-linked rows).
# FEEDBACK_RETENTION_DAYS="365"
# Optional: Google OAuth
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Migration (only needed when migrating from Contentful)
# CONTENTFUL_SPACE_ID=your_space_id_here
# CONTENTFUL_DELIVERY_TOKEN=your_delivery_token_here
# MIGRATION_USER_EMAIL=your_email@example.com

# Last.fm API (optional - for band data enrichment)
LASTFM_API_KEY=your_lastfm_key_here
LASTFM_SECRET=your_lastfm_secret_here

# Ticketmaster Discovery API (optional - for concert venue search)
# Get your free API key at https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# Feature Flags
# Set to 'true', '1', or 'yes' to enable
ENABLE_LASTFM=true
ENABLE_MUSICBRAINZ=true
# Merge MusicBrainz + Last.fm into band autocomplete (server-side; respects ENABLE_LASTFM for Last.fm)
ENABLE_EXTERNAL_BAND_SUGGEST=true
# Gate /map page (premium rollout)
ENABLE_MAP_PAGE=false
# Gate statistics charts widget on home/profile pages
ENABLE_STATISTICS_WIDGET=false

# Email (required for email/password auth with verification)
# Set up via Vercel Integration: https://vercel.com/integrations/resend
# Or manually at https://resend.com
# RESEND_API_KEY="re_your_api_key_here"
# EMAIL_FROM="noreply@yourdomain.com"  # Use "onboarding@resend.dev" for dev

# Map (OpenFreeMap - no API key required by default)
# Override with a custom MapLibre style URL if desired:
# NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

SETLISTFM_API_KEY=""
GROQ_API_KEY=""

# Development Tools
# Email of an existing user for screenshot script authentication
DEV_USER_EMAIL=""

# PostHog (EU Cloud) — page analytics; opt-in via NEXT_PUBLIC_POSTHOG_ENABLED
# https://posthog.com/docs/libraries/next-js
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
NEXT_PUBLIC_POSTHOG_ENABLED="false"
# Session replay remains off unless explicitly enabled and user consent is granted.
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY_ENABLED="false"

# Sentry (from https://sentry.io → Project Settings → Client Keys DSN)
NEXT_PUBLIC_SENTRY_DSN="https://...@....ingest.sentry.io/..."
# For source map upload in CI (Vercel: Project → Settings → Environment Variables)
SENTRY_AUTH_TOKEN=""
# Optional: CSP violation reports (Security Policy Reporting). If unset, SENTRY_ENVIRONMENT falls back to NODE_ENV.
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=1.0.0