  "author": "Sebastian Engel <sebastianengel@posteo.de>",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "better-auth": "^1.4.18",
    "contentful": "^11.10.5",
    "lastfm-ts-api": "^1.0.0",
    "maplibre-gl": "^5.19.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "prisma": "7.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet": "^6.1.0",
    "resend": "^6.9.3",
    "sharp": "^0.33.5",
    "standard-version": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.20.0",
    "eslint-config-next": "^16.1.6",
    "prettier": "^3.5.3",
    "puppeteer": "^24.38.0",
    "sass": "^1.97.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "nextjs",
    "concerts"
  ],
  "license": "MIT",
  "scripts": {
    "build": "prisma generate && next build",
    "dev": "prisma generate && next dev",
    "start": "next start",
    "format": "prettier --write ./src/**/*.{js,jsx,ts,tsx,scss}",
    "lint": "eslint .",
    "release": "standard-version",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "migrate:shared-concerts": "tsx --env-file=.env scripts/migrate-to-shared-concerts.ts",
    "migrate:supporting-acts": "tsx --env-file=.env scripts/migrate-supporting-acts.ts"
  },
  "resolutions": {
    "lodash": "^4.17.23",
    "hono": "^4.12.4",
    "@hono/node-server": "^1.19.10",
    "@types/pg": "^8.16.0"
  },
  "repository": {
    "type": "git",
